# Runtime
NODE_ENV=production
PORT=8787
SDAL_BASE_URL=https://example.com
SDAL_SESSION_SECRET=change-this-long-random-value
SDAL_ADMIN_PASSWORD=change-this-too
ROOT_BOOTSTRAP_PASSWORD=
SDAL_SLOW_QUERY_MS=200
SDAL_LEGACY_ROOT_DIR=/var/lib/sdal/legacy-logs

# Driver selection
SDAL_DB_DRIVER=sqlite

# SQLite persistence (single-droplet default)
SDAL_DB_PATH=/var/lib/sdal/data/sdal.sqlite
SDAL_UPLOADS_DIR=/var/lib/sdal/uploads
SDAL_DB_REQUIRE_EXISTING=true
SDAL_DB_REQUIRED_TABLE=uyeler
SDAL_DB_AUTO_REPAIR_MISSING_SCHEMA=true
SDAL_DB_BOOTSTRAP_PATH=
SDAL_DB_DIR=

# PostgreSQL (Phase 2 foundation / Phase 3 migration target)
# Set SDAL_DB_DRIVER=postgres when cutover is ready.
DATABASE_URL=postgresql://sdal_app:CHANGE_ME@127.0.0.1:5432/sdal_prod
PGSSLMODE=disable
PGPOOL_MAX=20
PGPOOL_MIN=2
PGPOOL_IDLE_MS=30000
PGPOOL_CONNECT_TIMEOUT_MS=5000
PG_QUERY_TIMEOUT_MS=20000
PG_STATEMENT_TIMEOUT_MS=15000

# Redis (sessions, cache, pub/sub, rate-limit groundwork)
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379/0
REDIS_SESSION_PREFIX=sdal:sess:
REDIS_CONNECT_TIMEOUT_MS=4000
REDIS_RETRY_MAX_DELAY_MS=5000
REDIS_KEEPALIVE_MS=5000
REDIS_PING_INTERVAL_MS=30000

# Realtime + background jobs (Phase 6)
JOB_QUEUE_NAMESPACE=sdal:jobs:main
JOB_INLINE_WORKER=false
WS_ALLOW_LEGACY_QUERY_AUTH=false

# Idempotency (seconds)
IDEMPOTENCY_POST_PENDING_TTL_SECONDS=45
IDEMPOTENCY_POST_RESPONSE_TTL_SECONDS=240
IDEMPOTENCY_CHAT_PENDING_TTL_SECONDS=20
IDEMPOTENCY_CHAT_RESPONSE_TTL_SECONDS=180
IDEMPOTENCY_MESSENGER_PENDING_TTL_SECONDS=25
IDEMPOTENCY_MESSENGER_RESPONSE_TTL_SECONDS=180

# Cache TTL tuning (seconds)
FEED_CACHE_TTL_SECONDS=20
PROFILE_CACHE_TTL_SECONDS=25
STORY_RAIL_CACHE_TTL_SECONDS=20
ADMIN_SETTINGS_CACHE_TTL_SECONDS=45

# Redis-backed rate limits (falls back to in-memory when Redis is unavailable)
RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_LOGIN_WINDOW_SECONDS=600
RATE_LIMIT_CHAT_SEND_MAX=30
RATE_LIMIT_CHAT_SEND_WINDOW_SECONDS=60
RATE_LIMIT_POST_WRITE_MAX=20
RATE_LIMIT_POST_WRITE_WINDOW_SECONDS=600
RATE_LIMIT_COMMENT_WRITE_MAX=30
RATE_LIMIT_COMMENT_WRITE_WINDOW_SECONDS=600
RATE_LIMIT_UPLOAD_MAX=25
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=600

# Upload abuse controls / quotas
MEDIA_MAX_UPLOAD_BYTES=10485760
UPLOAD_QUOTA_WINDOW_SECONDS=86400
UPLOAD_QUOTA_MAX_FILES=140
UPLOAD_QUOTA_MAX_BYTES=367001600
UPLOAD_QUOTA_ADMIN_MULTIPLIER=3

# Email provider (existing runtime vars)
MAIL_ALLOW_MOCK=true
MAIL_SEND_TIMEOUT_MS=10000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=change-this-password
SMTP_FROM=SDAL <noreply@example.com>
SMTP_TLS_REJECT_UNAUTHORIZED=true
RESEND_API_KEY=
RESEND_FROM=SDAL <noreply@example.com>

# Email aliases (for ops consistency)
MAIL_PROVIDER=smtp
MAIL_FROM=SDAL <noreply@example.com>
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=mailer@example.com
MAIL_SMTP_PASS=change-this-password

# Storage provider (existing runtime vars)
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=
SPACES_REGION=
SPACES_ENDPOINT=

# Storage aliases (for future provider abstraction)
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=/var/lib/sdal/uploads
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=

# OAuth integrations
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://example.com/api/auth/oauth/google/callback
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=https://example.com/api/auth/oauth/x/callback
